                //si pasa la validacion
				const pjNit = document.getElementById('pjNIT');
				if (pjNit) pjNit.removeAttribute('disabled');
                const data = collectFormData_Juridica();
				if (pjNit) pjNit.setAttribute('disabled', 'disabled');
                console.log('payload jurídica', data);
                sendData(data, isNewDetail ? '/Admin/AddProviderJuridica' : '/Admin/UpdateProviderJuridica');
