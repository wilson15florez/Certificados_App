<!DOCTYPE html>
<html lang="es-co">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="~/css/style.css" rel="stylesheet" />
    <link href="~/css/alerts.css" rel="stylesheet" />
    <link href="~/css/styleFormUnicProv.css" rel="stylesheet" />
    <link href="~/images/icono-web.webp" rel="icon" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">
    <title>Proveedores USC</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/18.2.1/css/intlTelInput.css">
    <!-- Ajuste para que el input ocupe todo el ancho con el selector de país -->
    <style>.iti { width: 100%; display: block; }</style>

    <!-- jQuery (obligatorio para Select2) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Select2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <!-- Select2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

</head>
<body>
    <main class="main-page-container-height">
        @Html.Partial("_NavAdmin")
        <section class="page-content">
            <div class="content-header">
				<h1>Formato Único de Conocimiento de Proveedores</h1>
            </div>

            <!-- Sub nav de acciones-->
            <div class="row d-flex justify-content-around align-items-center card flex-row m-2 p-2">
                <div class="col form-group">
                    <button id="openFormsBtn" type="button" class="btn btn-primary">Llenar o Actualizar Informacion del Formato</button>
                </div>
                <div class="col form-group">
                    <button id="uploadDocsBtn" type="button" class="btn btn-primary">Subir Documentos Anexos</button>
                </div>
                <div class="col form-group">
                    <button id="printFormatBtn" type="button" class="btn btn-primary">imprimir Formato</button>
                </div>
            </div>

            @* Contenido de openForms *@
            <!-- bloque de consulta-->
            <div id="consultForm" class="form-section" style="display:none;">
                <div class="row d-flex justify-content-center align-items-center card flex-row m-2 p-2">
                    <div class="col form-group d-block custom-input-group">
                        <label for="personType" class="form-label">Seleccione el Tipo de Persona *</label>
                        <select id="personType" class="form-control">
                            <option value="" disabled selected>Seleccione una opción</option>
                            <option value="natural">Persona Natural</option>
                            <option value="juridica">Persona Jurídica</option>
                        </select>
                    </div>
                    <div id="idSection" class="col form-group d-block input-wrapper">
                        <input type="number" id="idNum" name="idNum" class="form-control" />
                        <label for="idNum" class="form-label adaptive-label" placeholder="Número de Identificación *" alt="Número de Identificación *"></label>
                    </div>
                    <div class="col-1 form-group d-block">
                        <button id="consultBtn" type="button" class="btn btn-primary">Consultar</button>
                    </div>
                </div>
            </div>
            
            <div id="alertContainer"></div>
            <!-- form de persona natural-->
            <form id="persNatuForm" class="form-section" style="display:none;" autocomplete="off">

                <div class="justify-content-around align-items-center flex-row m-2 p-2">
                    <h2>Persona Natural</h2>
                </div>
                
                <div>
                    <div class="d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="form-group input-wrapper">
                            <input type="text" id="pnNombreCompl" name="pnNombreCompl" class="form-control" required />
                            <label for="pnNombreCompl" class="form-label adaptive-label" placeholder="Nombre Completo *" alt="Nombre Completo *"></label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="form-group d-block custom-input-group">
                            <label for="pnTipoNacionalidad" class="form-label">Tipo de Nacionalidad *</label>
                            <select id="pnTipoNacionalidad" class="form-control">
                                <option value="" disabled selected>Seleccione una opcion</option>
                                <option value="Nacional">Nacional</option>
                                <option value="Extranjero">Extranjero</option>
                            </select>
                        </div>
                        <div class="form-group d-block custom-input-group">
                            <label for="pnTipoDoc" class="form-label">Tipo de Documento *</label>
                            <select id="pnTipoDoc" class="form-control">
                                <option value="" disabled selected>Seleccione un documento</option>
                            </select>
                        </div>
                        <div class="form-group input-wrapper">
                            <input type="number" id="pnNumId" name="pnDocNum" class="form-control no-edit" required />
                            <label for="pnNumId" class="form-label adaptive-label disabled-label" placeholder="Número de documento *" alt="Número de documento *"></label>
                        </div>
                    </div>

                    <div class="row d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="col-5 mb-3 form-group input-wrapper">
                            <input type="date" id="pnFechaExpDoc" name="pnFechaExpDoc" class="form-control" required />
                            <label for="pnFechaExpDoc" class="form-label adaptive-label" placeholder="Fecha de Expedición de Documento *" alt="Fecha de Expedición de Documento *"></label>
                        </div>
                        <div class="col mb-3 form-group d-block custom-input-group">
                            <label for="pnDepExpDoc" class="form-label">Departamento de Expedición de Documento *</label>
                            <select id="pnDepExpDoc" name="pnDepExpDoc" class="form-control" required></select>
                        </div>
                        <div class="col mb-3 form-group d-block custom-input-group">
                            <label for="pnCiuExpDoc" class="form-label">Ciudad de Expedición de Documento *</label>
                            <select id="pnCiuExpDoc" name="pnCiuExpDoc" class="form-control" required></select>
                        </div>
                    </div>

                    <div class="row d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="col form-group d-block custom-input-group">
                            <label for="pnNacionalidad" class="form-label">Nacionalidad/Pais Origen *</label>
                            <select id="pnNacionalidad" name="pnNacionalidad" class="form-control" required></select>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pnEstadoNac" class="form-label">Departamento de nacimiento *</label>
                            <select id="pnEstadoNac" name="pnEstadoNac" class="form-control" required></select>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pnCiudadNac" class="form-label">Ciudad de nacimiento *</label>
                            <select id="pnCiudadNac" name="pnCiudadNac" class="form-control" required></select>
                        </div>
                    </div>

                    <div class="row d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="col mb-3 form-group input-wrapper">
                            <input type="date" id="pnFechaNac" name="pnFechaNac" class="form-control" required />
                            <label for="pnFechaNac" class="form-label adaptive-label" placeholder="Fecha de Nacimiento *" alt="Fecha de Nacimiento *"></label>
                        </div>
                        <div class="col form-group input-wrapper">
                            <input type="text" id="pnDiResidencia" name="pnDiResidencia" class="form-control" required />
                            <label for="pnDiResidencia" class="form-label adaptive-label" placeholder="Dirección de Residencia *" alt="Dirección de Residencia *"></label>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pnDepRes" class="form-label">Departamento de Residencia *</label>
                            <select id="pnDepRes" name="pnDepRes" class="form-control" required></select>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pnCiudadRes" class="form-label">Ciudad de Residencia *</label>
                            <select id="pnCiudadRes" name="pnCiudadRes" class="form-control" required></select>
                        </div>
                    </div>

                    <div class="row d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="col form-group input-wrapper">
                            <input type="tel" id="pnTelefono" name="pnTelefono" class="form-control" autocomplete="new-password"/>
                            <label for="pnTelefono" class="form-label adaptive-label" placeholder="Teléfono Fijo" alt="Teléfono Fijo"></label>
                        </div>
                        <div class="col form-group input-wrapper">
                            <input type="tel" id="pnCelular" name="pnCelular" class="form-control" autocomplete="new-password" required/>
                            <label for="pnCelular" class="form-label adaptive-label" placeholder="Teléfono Celular *" alt="Teléfono Celular *"></label>
                        </div>
                        <div class="col form-group input-wrapper">
                            <input type="email" id="pnEmail" name="pnEmail" class="form-control" required/>
                            <label for="pnEmail" class="form-label adaptive-label" placeholder="Correo Electrónico *" alt="Correo Electrónico *"></label>
                        </div>
                    </div>

                    <div class="row d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="col form-group input-wrapper">
                            <input type="text" id="pnOficProfe" name="pnOficProfe" class="form-control"/>
                            <label for="pnOficProfe" class="form-label adaptive-label" placeholder="Oficio o Profesión" alt="Oficio o Profesión"></label>
                        </div>
                        <div class="col mb-3 form-group d-block custom-input-group">
                            <label for="pnActividad" class="form-label">Actividad *</label>
                            <select id="pnActividad" name="pnActividad" class="form-control">
                                <option value="" disabled selected>Seleccione una opción</option>
                                <option value="dependiente">Dependiente</option>
                                <option value="independiente">Independiente</option>
                            </select>
                        </div>
                    </div>

                    <div class="row d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <h4 class="sub-header">Marque según su perfil, cargo y/u ocupación</h4>
                        <div class="row d-flex">
                            <div class="col form-group input-wrapper form-check">
						        <label>Goza de Reconocimiento Público *</label>
                                <div class="d-flex">
                                    <div class="form-check m-2">
                                        <input type="radio" id="pnReconoPblSi" name="pnReconoPublic" value="Si" class="form-check-input" /><label for="pnReconoPblSi" class="form-check-label">Sí</label>
                                    </div>
                                    <div class="form-check m-2">
                                        <input type="radio" id="pnReconoPblNo" name="pnReconoPublic" value="No" class="form-check-input" /><label for="pnReconoPblNo" class="form-check-label">No</label>
                                    </div>
                                </div>
                            </div>
                            <div class="col form-group input-wrapper form-check">
                                <label>Maneja Recursos Públicos *</label>
						        <div class="d-flex">
                                    <div class="form-check m-2">
                                        <input type="radio" id="pnManRePubSi" name="pnManRePub" value="Si" class="form-check-input" /><label for="pnManRePubSi" class="form-check-label">Sí</label>
                                    </div>
                                    <div class="form-check m-2">
                                        <input type="radio" id="pnManRePubNo" name="pnManRePub" value="No" class="form-check-input" /><label for="pnManRePubNo" class="form-check-label">No</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row d-flex">
                            <div class="col form-group input-wrapper form-check">
                                <label>Es Persona Expuesta Politicamente *</label>
                                <div class="d-flex">
                                    <div class="form-check m-2">
                                        <input type="radio" id="pnPEPSi" name="pnPEP" value="Si" class="form-check-input"/><label for="pnPEPSi" class="form-check-label">Sí</label>
                                    </div>
                                    <div class="form-check m-2">
                                        <input type="radio" id="pnPEPNo" name="pnPEP" value="No" class="form-check-input"/><label for="pnPEPNo" class="form-check-label">No</label>
                                    </div>
                                </div>
                            </div>
                            <div class="col form-group input-wrapper form-check" id="pnPEPtypeGroup" style="display:none;">
                                <label>Tipo de PEP *</label>
                                <div class="d-flex">
                                    <div class="form-check m-2">
                                        <input type="checkbox" id="pnPEP-Nac" name="pnPEPType" value="1" class="form-check-input"/><label for="pnPEP-Nac" class="form-check-label">PEP Nacional</label>
                                    </div>
                                    <div class="form-check m-2">
                                        <input type="checkbox" id="pnPEP-OrgInt" name="pnPEPType" value="2" class="form-check-input"/><label for="pnPEP-OrgInt" class="form-check-label">PEP Org.Internacional</label>
                                    </div>
                                    <div class="form-check m-2">
                                        <input type="checkbox" id="pnPEP-Ext" name="pnPEPType" value="3" class="form-check-input"/><label for="pnPEP-Ext" class="form-check-label">PEP Extranjero</label>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group input-wrapper" id="pnPEP_Entidad_Container" style="display:none;">
                                <input type="text" id="pnPEP_Entidad" name="pnPEP_Entidad" class="form-control" required />
                                <label for="pnPEP_Entidad" class="form-label adaptive-label" placeholder="Entidad a la que pertenece *" alt="Entidad a la que pertenece *"></label>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            <!-- form de persona juridica-->
            <form id="persJuriForm" class="form-section" style="display:none;" autocomplete="off">

                <div class="justify-content-around align-items-center flex-row m-2 p-2">
                    <h2>Persona Jurídica</h2>
                </div>
                
                <div>
                    <div class="d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="form-group input-wrapper">
                            <input type="text" id="pjRazSocial" name="pjRazSocial" class="form-control" required />
                            <label for="pjRazSocial" class="form-label adaptive-label" placeholder="Razón Social *" alt="Razón Social *"></label>
                        </div>
                        <div class="form-group input-wrapper">
                            <input type="number" id="pjNIT" name="pjNIT" class="form-control no-edit" required />
                            <label for="pjNIT" class="form-label adaptive-label disabled-label" placeholder="NIT *" alt="NIT *"></label>
                        </div>
                    </div>

                    <div class="justify-content-around align-items-center flex-row m-2 p-2">
                        <h3 class="sub-header">Direcciones</h3>
                        <div class="d-flex">
                            <div class="form-group input-wrapper">
                                <input type="text" id="pjDirPrincipal" name="pjDirPrincipal" class="form-control" autocomplete="off" required />
                                <label for="pjDirPrincipal" class="form-label adaptive-label" placeholder="Dirección Oficina Principal *" alt="Dirección Oficina Principal *"></label>
                            </div>
                            <div class="form-group d-block custom-input-group">
                                <label for="pjDepartDirPrincipal" class="form-label">Departamento *</label>
                                <select id="pjDepartDirPrincipal" name="pjDepartDirPrincipal" class="form-control" required></select>
                            </div>
                            <div class="form-group d-block custom-input-group">
                                <label for="pjCiudadDirPrincipal" class="form-label">Ciudad *</label>
                                <select id="pjCiudadDirPrincipal" name="pjCiudadDirPrincipal" class="form-control" required></select>
                            </div>
                        </div>
                        <div class="d-flex justify-content-around align-items-center flex-row m-2 p-2">
                            <div class="form-group input-wrapper">
                                <input type="email" id="pjEmailDirPrincipal" name="pjEmailDirPrincipal" class="form-control" required />
                                <label for="pjEmailDirPrincipal" class="form-label adaptive-label" placeholder="E-mail *" alt="E-mail *"></label>
                            </div>
                            <div class="form-group input-wrapper">
                                <input type="tel" id="pjTelDirPrincipal" name="pjTelDirPrincipal" class="form-control" autocomplete="new-password" required />
                                <label for="pjTelDirPrincipal" class="form-label adaptive-label" placeholder="Teléfono *" alt="Teléfono *"></label>
                            </div>
                        </div>
                    </div>
                    

                    <div id="sucursales-container">
                        <div class="sucursal-item justify-content-around align-items-center flex-row m-2 p-2">
                            
                        </div>
                    </div>
                    <div class="justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="form-group">
                            <button id="addSucursalBtn" type="button" class="button-group btn btn-primary">Agregar Sucursal</button>
                        </div>
                    </div>

                    <div class="justify-content-around align-items-center flex-row m-2 p-2">
                        <p class="sub-header">
                            Identifique la persona natural que ejerza control sobre la persona juridica o que sea titular, directa o indirectamente, del cinco por ciento (5%)
                            o más del capital o derechos de voto y/o se beneficie en un cinco por ciento (5%) o mas de los rendimientos, utilidades o Activos.
                        </p>
                        <p>En caso de requerir más espacios debe anexarse la relación.</p>
                    </div>

                    <div class="justify-content-around align-items-center flex-row m-2 p-2">
                        <table class="table table-hover" id="control-table">
                            <thead>
                                <tr>
                                    <th scope="col">Razón Social o Nombre Completo</th>
                                    <th scope="col">Tipo de Identificación</th>
                                    <th scope="col">Número de Identificación</th>
                                    <th scope="col">Porcentaje de Participación (%)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="control-row">
                                    <td><input type="text" class="form-control" name="controlRazonSocial[]" style="width:100%;" /></td>
                                    <td>
                                        <select class="form-control" name="controlIdType[]">
                                            <option value="" disabled selected>Seleccione</option>
                                            <option value="CC">CC</option>
                                            <option value="NIT">NIT</option>
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control" name="controlIdNum[]" style="width:100%;" /></td>
                                    <td><input type="number" class="form-control" name="controlPorcentaje[]" style="width:100%;" /></td>
                                    <td><button type="button" class="remove-control-row button-group btn btn-primary">Eliminar</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="justify-content-around align-items-center flex-row m-2 p-2">
                        <button id="addControlRowBtn" type="button" class="button-group button-group btn btn-primary">Agregar Fila</button>
                    </div>

                    <!-- Subform de representante legal-->
                    <div class="justify-content-around align-items-center flex-row m-2 p-2">
                        <h3>Información del Representante Legal</h3>
                    </div>
                    <div class="d-flex justify-content-around align-items-center  m-2 p-2">
                        <div class="form-group input-wrapper">
                            <input type="text" id="pjNomReLeg" name="pjNomReLeg" class="form-control"/>
                            <label for="pjNomReLeg" class="form-label adaptive-label" placeholder="Nombre Completo *" alt="Nombre Completo *"></label>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="form-group d-block custom-input-group">
                            <label for="pjRLTipNacionalidad" class="form-label">Tipo de Nacionalidad *</label>
                            <select id="pjRLTipNacionalidad" class="form-control">
                                <option value="" disabled selected>Seleccione una opcion</option>
                                <option value="Nacional">Nacional</option>
                                <option value="Extranjero">Extranjero</option>
                            </select>
                        </div>
                        <div class="form-group d-block custom-input-group">
                            <label for="pjRLTipoDoc" class="form-label">Tipo de Documento *</label>
                            <select id="pjRLTipoDoc" class="form-control">
                                <option value="" disabled selected>Seleccione un documento</option>
                            </select>
                        </div>
                        <div class="form-group input-wrapper">
                            <input type="number" id="pjRLDocNum" name="pjRLDocNum" class="form-control" required />
                            <label for="pjRLDocNum" class="form-label adaptive-label" placeholder="Número de documento *" alt="Número de documento *"></label>
                        </div>
                    </div>

                    <div class="row d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="col mb-3 form-group input-wrapper">
                            <input type="date" id="pjRLFechExpDoc" name="pjRLFechExpDoc" class="form-control" required />
                            <label for="pjRLFechExpDoc" class="form-label adaptive-label" placeholder="Fecha de Expedición de Documento *" alt="Fecha de Expedición de Documento *"></label>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pjRLDepExpDoc" class="form-label">Departamento de Expedición de Documento *</label>
                            <select id="pjRLDepExpDoc" name="pjRLDepExpDoc" class="form-control" required></select>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pjRLCiuExpDoc" class="form-label">Ciudad de Expedición de Documento *</label>
                            <select id="pjRLCiuExpDoc" name="pjRLCiuExpDoc" class="form-control" required></select>
                        </div>
                    </div>

                    <div class="row d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="col mb-3 form-group input-wrapper">
                            <input type="date" id="pjRLFechaNac" name="pjRLFechaNac" class="form-control" required />
                            <label for="pjRLFechaNac" class="form-label adaptive-label" placeholder="Fecha de Nacimiento *" alt="Fecha de Nacimiento *"></label>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pjRLNacionalidad" class="form-label">Nacionalidad/Pais Origen *</label>
                            <select id="pjRLNacionalidad" name="pjRLNacionalidad" class="form-control" required></select>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pjRLDepartNac" class="form-label">Departamento de nacimiento *</label>
                            <select id="pjRLDepartNac" name="pjRLDepartNac" class="form-control" required></select>
                        </div>
                        <div class="col form-group d-block custom-input-group">
                            <label for="pjRLCiudadNac" class="form-label">Ciudad de nacimiento *</label>
                            <select id="pjRLCiudadNac" name="pjRLCiudadNac" class="form-control" required></select>
                        </div>
                    </div>
                </div>
            </form>

            <!-- form conocimiento proveedores (tanto para persona natural como juridica)-->
            <form id="provForm" class="form-section" style="display: none;" autocomplete="off">

                <div class="justify-content-around align-items-center flex-row m-2 p-2">
                    <h3>Información Financiera y Tributaria (Persona Natural / Jurídica)</h3>
                </div>

                <div>
                    <div class="d-flex justify-content-around align-items-center flex-row m-2 p-2">
                        <div class="form-group input-wrapper">
                            <input type="text" id="pvIngrMens" name="pvIngrMens" class="form-control" required />
                            <label for="pvIngrMens" class="form-label adaptive-label" placeholder="Ingresos Mensuales $ *" alt="Ingresos Mensuales $ *"></label>
                        </div>
