                            if (data.pjRLDepartNac) {
                                const states = await loadStates(data.pjRLNacionalidad);
                                fillSelect2('#pjRLDepartNac', states, '-- Seleccione estado --', 'id', 'name');
                                setSelect('pjRLDepartNac', data.pjRLDepartNac);
                                if (data.pjRLCiudadNac){
