				console.log('payload', data);
                sendData(data, isNewDetail ? '/Admin/AddProviderNatural' : '/Admin/UpdateProviderNatural');
            });

            document.getElementById('persJuriForm').addEventListener('submit', function(e) {
                e.preventDefault();
